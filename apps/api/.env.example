# Local commands fall back to this file when `.env` is missing.
PORT=4000
# Optional exact origin override for deployed frontends.
# Local development always allows http://localhost:3000-3010 and http://127.0.0.1:3000-3010.
WEB_ORIGIN=http://localhost:3000
DATABASE_URL="file:./dev.db"
SWEETBOOK_API_BASE_URL=https://api-sandbox.sweetbook.com/v1
SWEETBOOK_API_KEY=your_sandbox_api_key_here
SWEETBOOK_ESTIMATE_MODE=auto
SWEETBOOK_ORDER_MODE=local
SWEETBOOK_BOOK_SPEC_UID=SQUAREBOOK_HC
SWEETBOOK_COVER_TEMPLATE_UID=4MY2fokVjkeY
SWEETBOOK_CONTENT_TEMPLATE_UID=3FhSEhJ94c0T
SWEETBOOK_BLANK_TEMPLATE_UID=2mi1ao0Z4Vxl
SWEETBOOK_PUBLISH_TEMPLATE_UID=75vMl9IeyPMI
VERCEL_BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here
UPLOAD_STORAGE_DRIVER=local
R2_ACCOUNT_ID=your_cloudflare_account_id_here
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_BUCKET=your_r2_bucket_name_here
R2_PUBLIC_BASE_URL=https://your-public-r2-domain.example.com
